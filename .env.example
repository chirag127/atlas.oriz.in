# ═══════════════════════════════════════════════
# Atlas — .env.example
# Copy to .env.local and fill in values
# Everything works without any keys (Puter.js + DuckDuckGo need none)
# ═══════════════════════════════════════════════

# ── App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Atlas
NODE_ENV=development

# ── Supabase (Optional — app works without it using local SQLite fallback)
# Get from: https://supabase.com/dashboard → Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...

# ── Database (Supabase Postgres pooler)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── AI Providers (All optional — Puter.js works with zero config)
# OpenRouter — Get from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini — Get from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AI...

# Groq — Get from: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# Cerebras — Get from: https://cloud.cerebras.ai
# CEREBRAS_API_KEY=csk-...

# NVIDIA NIM — Get from: https://build.nvidia.com
# NVIDIA_API_KEY=nvapi-...

# Mistral — Get from: https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=...

# Codestral — Get from: https://codestral.mistral.ai
# CODESTRAL_API_KEY=...

# HuggingFace — Get from: https://huggingface.co/settings/tokens
# HUGGINGFACE_TOKEN=hf_...

# Cohere — Get from: https://dashboard.cohere.com/api-keys
# COHERE_API_KEY=...

# GitHub Models — Get from: https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_...

# Cloudflare Workers AI
# CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_API_TOKEN=...

# ── Discovery / Web Search (DuckDuckGo needs no key — always works)
# Serper — Get from: https://serper.dev
# SERPER_API_KEY=...

# Tavily — Get from: https://tavily.com
# TAVILY_API_KEY=...

# Brave Search — Get from: https://brave.com/search/api
# BRAVE_SEARCH_API_KEY=...

# Exa — Get from: https://exa.ai
# EXA_API_KEY=...

# ── Email (Resend — 3,000/month free)
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=atlas@oriz.in

# ── Push Notifications (VAPID)
# Generate: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=B...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:hi@oriz.in

# ── Encryption (AES-256-GCM for stored API keys)
# Generate: openssl rand -hex 32
# ENCRYPTION_KEY=...

# ── Cron Security
# Generate: openssl rand -hex 16
# CRON_SECRET=...

# ── Feature Flags
NEXT_PUBLIC_ENABLE_GAMIFICATION=true
NEXT_PUBLIC_ENABLE_PUSH=true
NEXT_PUBLIC_ENABLE_TTS=true
NEXT_PUBLIC_ENABLE_DISCOVERY=true
NEXT_PUBLIC_ENABLE_KNOWLEDGE_GRAPH=true
