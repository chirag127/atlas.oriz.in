# ==============================================================================
# ATLAS PWA CONFIGURATION — LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# ==============================================================================

# Core Project Environment
NODE_ENV=development
PORT=5173

# Firebase Authentication Configuration (Client-side Config)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Cloudflare Pages / D1 Database bindings (Local emulator configs)
# These are referenced during local wrangler emulation
CLOUDFLARE_ACCOUNT_ID=
D1_DATABASE_ID=
KV_NAMESPACE_ID=

# Default Server-Side Fallback Keys (Optional)
# If provided, these serve as defaults when users haven't configured their own BYOK keys.
# Keep empty in production to enforce complete client-side BYOK privacy.
DEFAULT_OPENROUTER_API_KEY=
DEFAULT_GEMINI_API_KEY=
DEFAULT_GROQ_API_KEY=
DEFAULT_CEREBRAS_API_KEY=

# System settings
ENABLE_ANALYTICS=false
LOG_LEVEL=info
